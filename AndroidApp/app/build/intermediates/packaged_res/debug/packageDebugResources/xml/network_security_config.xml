<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for your local development server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.53.54</domain>
    </domain-config>

    <!-- Optional: also allow localhost for emulator testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
