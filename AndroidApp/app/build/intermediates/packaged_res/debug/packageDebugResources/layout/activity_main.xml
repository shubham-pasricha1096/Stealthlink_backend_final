<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark_gradient">

    <!-- App Logo or Title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="StealthLink Secure Access"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/montserrat_semibold"
        android:layout_marginBottom="60dp"/>

    <!-- Scan QR Button -->
    <Button
        android:id="@+id/btnScanQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan OTP QR Code"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_medium"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_primary"
        android:padding="14dp"
        android:layout_marginBottom="20dp"/>

    <!-- Pick Image Button -->
    <Button
        android:id="@+id/btnPickQRImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick QR from Gallery"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_medium"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_secondary"
        android:padding="14dp"/>

    <Button
        android:id="@+id/btnEnterOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter OTP Manually"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_medium"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_secondary"
        android:padding="14dp"
        android:layout_marginTop="20dp"/>


</LinearLayout>
