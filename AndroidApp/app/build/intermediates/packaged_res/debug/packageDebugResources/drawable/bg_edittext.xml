<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Dark base -->
    <solid android:color="#141427" />

    <!-- Slight inner border glow -->
    <stroke
        android:width="1.5dp"
        android:color="#3F51B5" />

    <!-- Rounded corners -->
    <corners android:radius="10dp" />

    <!-- Subtle inner padding (to keep text from touching edges) -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

</shape>
